{"lexicon" 1
 "id" "com.etzhayyim.uchiwake.registerBomEdge"
 "defs" {"main" {"type" "procedure"
 "description" "Assert a first-class BILL-OF-MATERIALS edge (parent CONTAINS child) into the kotoba Datom log (:bom.edge/*). parent \u2192 :product/id or :part/id; child \u2192 :part/id or :material/id. Records a PUBLIC decomposition only (teardown / ingredient label / supplier-list filing), with a bounded quantity + dependency-strength estimate. AGGREGATE-FIRST + sourcing-honest (uchiwake G2/G5): quantity & criticality are :representative, NEVER a confidential recipe or contract figure, and framed toward redundancy + accountability \u2014 never a clone/counterfeit recipe or interdiction map."
 "input" {"encoding" "application/json"
 "schema" {"type" "object"
 "required" ["edgeId"
 "parent"
 "child"
 "sourcing"
 "observedAt"]
 "properties" {"edgeId" {"type" "string"
 "description" ":bom.edge/id"}
 "parent" {"type" "string"
 "description" ":product/id or :part/id (the assembly)"}
 "child" {"type" "string"
 "description" ":part/id or :material/id (the constituent)"}
 "qtyMilli" {"type" "integer"
 "description" "quantity of child per one parent in THOUSANDTHS (magnitude \u00D7 1000, integer implied units); bounded public estimate, NEVER a confidential recipe"}
 "qtyUnit" {"type" "string"
 "description" "e.g. \"unit\", \"g\", \"%mass\""}
 "tier" {"type" "integer"
 "description" "BOM depth tier: 1 = direct component of finished good"}
 "supplier" {"type" "string"
 "description" "\u2192 kabuto :company/id of the disclosed supplier of the child, if known"}
 "criticalityBp" {"type" "integer"
 "minimum" 0
 "maximum" 1000
 "description" "0..1000 = 0.0..1.0 (integer implied units); how single-sourced / hard-to-substitute the child is. NOT a contract figure"}
 "sourcing" {"type" "string"
 "enum" ["authoritative"
 "representative"
 "synthesized"]
 "description" "uchiwake G5; BOM decompositions are typically :representative"}
 "observedAt" {"type" "string"
 "format" "datetime"}}}}
 "output" {"encoding" "application/json"
 "schema" {"type" "object"
 "properties" {"ok" {"type" "boolean"}
 "edgeId" {"type" "string"}
 "txCid" {"type" "string"
 "description" "kotoba transaction CID"}
 "datomCount" {"type" "integer"}
 "error" {"type" "string"}}}}}}}
